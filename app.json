{
  "expo": {
    "name": "Astroayan",
    "slug": "astroayan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d0610"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jothidam.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0610"
      },
      "package": "com.jothidam.app"
    },
    "web": {
	  "name": "Astroayan",
      "shortName": "Astroayan",
      "description": "Horoscope, birth chart readings and daily astrology predictions",
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "jothidam"
  }
}
